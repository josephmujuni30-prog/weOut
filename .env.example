# ── Gemini AI ──────────────────────────────────────────────────────────────────
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# ── App URL ────────────────────────────────────────────────────────────────────
APP_URL="MY_APP_URL"

# ── Google Maps (optional) ─────────────────────────────────────────────────────
VITE_GOOGLE_MAPS_API_KEY=

# ── M-Pesa Daraja (STK Push) ───────────────────────────────────────────────────
# Get these from https://developer.safaricom.co.ke/MyApps

# "sandbox" for testing, "production" for live
MPESA_ENV=sandbox

# From your Daraja app's Consumer Key
MPESA_CONSUMER_KEY=your_consumer_key_here

# From your Daraja app's Consumer Secret
MPESA_CONSUMER_SECRET=your_consumer_secret_here

# Your Paybill or Till Number (sandbox default: 174379)
MPESA_SHORTCODE=174379

# Lipa Na M-Pesa Online Passkey (from Daraja dashboard or sandbox default below)
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# Public HTTPS URL where Daraja sends payment callbacks
# For local testing use ngrok: https://yoursubdomain.ngrok.io/api/mpesa/callback
MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback

# ── Dev settings ───────────────────────────────────────────────────────────────
DISABLE_HMR=true
